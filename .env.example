# ============================================================
# x-post-bridge 環境変数テンプレート
# このファイルを .env.local にコピーして値を埋めてください
# ============================================================

# ----------------------------
# Database (PostgreSQL)
# ----------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/x_post_bridge"

# ----------------------------
# X API v2 (developer.x.com で取得)
# OAuth 2.0 Authorization Code with PKCE (投稿用)
# ----------------------------
X_CLIENT_ID=""
X_CLIENT_SECRET=""
X_CALLBACK_URL="http://localhost:3000/api/auth/x/callback"

# ----------------------------
# X API v2 - アカウント分析用
# Bearer Token (App-only auth) ※ 投稿用の OAuth とは別
# developer.x.com > Your App > Keys and Tokens > Bearer Token
# ⚠️ Free tier: 月500リクエスト制限あり
# ⚠️ impression_count は Basic tier 以上が必要な場合あり
# 未設定でも「デモデータ」「CSV アップロード」で分析可能
# ----------------------------
X_BEARER_TOKEN=""

# ----------------------------
# セキュリティ
# ----------------------------
# 32バイト以上のランダム文字列 (openssl rand -base64 32 で生成)
ENCRYPTION_KEY=""

# Cron エンドポイント保護用シークレット
CRON_SECRET=""

# NextAuth / セッション管理用 (openssl rand -base64 32)
NEXTAUTH_SECRET=""

# ----------------------------
# App
# ----------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
